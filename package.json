{
  "name": "openmail",
  "description": "The open-source TUI email client",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "bun run --cwd packages/openmail --conditions=browser src/index.tsx",
    "typecheck": "bun turbo typecheck"
  },
  "workspaces": ["packages/*"],
  "devDependencies": {
    "turbo": "2.8.13",
    "typescript": "5.8.2"
  },
  "prettier": {
    "semi": false,
    "printWidth": 120
  }
}
